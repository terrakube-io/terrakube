<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet id="2-31-0-federated-credentials" author="alfespa17@gmail.com">
        <createTable tableName="federated">
            <column name="id" type="varchar(36)">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="issuer_url" type="varchar(256)">
                <constraints nullable="true"/>
            </column>
            <column name="audience" type="varchar(256)">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="datetime"/>
            <column name="updated_date" type="datetime"/>
            <column name="created_by" type="varchar2(128)"/>
            <column name="updated_by" type="varchar2(128)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
