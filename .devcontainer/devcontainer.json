// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node-postgres
{
  "name": "Terrakube Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "terrakube-dev",
  "workspaceFolder": "/workspaces/terrakube",

  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "installMaven": false,
      "jdkDistro": "Liberica",
      "version": "25.0.1-librca"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "installYarnUsingApt": true
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "terragrunt": "none",
      "tflint": "none"
    }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // This can be used to network with other containers or with the host.
  // "forwardPorts": [3000, 5432],

  // Run before building the container to initialize the environment (network + certificates)
  "initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/init-devcontainer.sh",

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "bash -c 'npm install -g yarn && /workspaces/terrakube/scripts/setupDevelopmentEnvironment.sh'",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        // Java development
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-boot-dashboard",
        "Pivotal.vscode-spring-boot",
        // JavaScript/TypeScript
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        // Claude Code
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      }
    }
  },

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  "remoteUser": "vscode",

  // Forward ports for Terrakube services
  "forwardPorts": [8080, 3000, 8075, 8090, 5556],

  // Make all forwarded ports public for easy access in Codespaces
  "portsAttributes": {
    "3000": {
      "label": "Terrakube UI",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8080": {
      "label": "Terrakube API",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8075": {
      "label": "Terrakube Registry",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8090": {
      "label": "Terrakube Executor",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "5556": {
      "label": "DEX (Authentication)",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  }
}